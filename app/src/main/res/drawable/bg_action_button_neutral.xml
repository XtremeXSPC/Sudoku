<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/ripple_action_neutral">

    <!-- Clip mask: keeps ripple inside the rounded corners -->
    <item android:id="@android:id/mask">
        <shape android:shape="rectangle">
            <solid android:color="@android:color/white" />
            <corners android:radius="16dp" />
        </shape>
    </item>

    <!-- Disabled state -->
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/surfaceVariant" />
            <stroke
                android:width="1dp"
                android:color="@color/outlineVariant" />
            <corners android:radius="16dp" />
        </shape>
    </item>

    <!-- Default / pressed state (ripple handles the visual feedback) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/surface" />
            <stroke
                android:width="1dp"
                android:color="@color/outline" />
            <corners android:radius="16dp" />
        </shape>
    </item>

</ripple>
