<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="StatsTextViewStyle">
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/onSurfaceVariant</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="ActionButtonStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:minHeight">60dp</item>
        <item name="android:background">@drawable/bg_action_button_neutral</item>
        <item name="android:elevation">5dp</item>
        <item name="android:gravity">center</item>
        <item name="android:maxLines">2</item>
        <item name="android:outlineProvider">background</item>
        <item name="android:stateListAnimator">@animator/button_elevation_anim</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/onSurface</item>
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">serif</item>
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">14dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
    </style>

    <style name="ActionButtonStyle.Accent" parent="ActionButtonStyle">
        <item name="android:background">@drawable/bg_action_button_accent</item>
        <item name="android:textColor">@color/onPrimary</item>
    </style>
</resources>
